{
    "manifest_version": 3,
    "name": "Biscotti",
    "version": "1.0.0",
    "description": "Delete cookies from the current page instantly.",
    "action": {
        "default_popup": "popup.html",
        "default_icon": {
            "16": "icons/icon16.png",
            "48": "icons/icon48.png",
            "128": "icons/icon128.png"
        }
    },
    "permissions": ["cookies", "activeTab", "tabs"],
    "host_permissions": ["<all_urls>"],
    "icons": {
        "16": "icons/icon16.png",
        "48": "icons/icon48.png",
        "128": "icons/icon128.png"
    },
    "browser_specific_settings": {
        "gecko": {
            "id": "biscotti@framicheli",
            "strict_min_version": "109.0"
        }
    }
}
